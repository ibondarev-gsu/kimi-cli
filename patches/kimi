#!/usr/bin/env python
"""Proxy-patched entry point for dev kimi-cli."""

import re
import pathlib

# Fix: kimi-dev writes type="zai" which is not a valid provider type — auto-correct to "kimi"
_config_path = pathlib.Path.home() / ".kimi" / "config.toml"
if _config_path.exists():
    _text = _config_path.read_text()
    _fixed = re.sub(r'^type\s*=\s*"zai"', 'type = "kimi"', _text, flags=re.MULTILINE)
    if _fixed != _text:
        _config_path.write_text(_fixed)

import aiohttp_proxy_patch  # noqa: E402
from kimi_cli.__main__ import main  # noqa: E402
import sys  # noqa: E402

raise SystemExit(main(sys.argv[1:]))
